# Create API_KEY at: https://lattifai.com/dashboard/api-keys
LATTIFAI_API_KEY=your_api_key_here  # lf_xxxx

# Gemini API KEY at: https://aistudio.google.com/api-keys
GEMINI_API_KEY=your_gemini_api_key_here  # AIzaSyxxxx

# OpenAI-compatible API (for translation with provider=openai)
# Supports SiliconFlow, OpenRouter, local vLLM, etc.
# OPENAI_API_KEY=sk-xxxx
# OPENAI_API_BASE_URL=https://api.siliconflow.cn/v1  # or OPENAI_API_BASE
# OPENAI_MODEL=Qwen/Qwen3-32B

# Enable dryrun mode for CLI tests
LATTIFAI_TESTS_CLI_DRYRUN=true
